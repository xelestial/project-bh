{
  "name": "project-bh",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:server": "node --watch --experimental-strip-types apps/server/src/http-server.ts",
    "dev:web": "node --experimental-strip-types apps/web/dev-server.ts",
    "test": "node --experimental-strip-types --test packages/**/*.test.ts apps/**/*.test.ts",
    "test:watch": "node --experimental-strip-types --test --watch packages/**/*.test.ts apps/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:web": "node --experimental-strip-types apps/web/build.ts"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.4",
    "typescript": "^5.9.3",
    "vite": "^7.1.10",
    "ws": "^8.18.3"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
